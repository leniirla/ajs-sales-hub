# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Postgres connection string used by Prisma / the Express API server.
# For Vercel/serverless deployments, use a pooled connection string (e.g. Neon's
# "-pooler" host) since every cold start opens a fresh connection.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# DIRECT_URL: Non-pooled Postgres connection string, used only by the Prisma CLI
# (migrate/generate/studio) — see prisma.config.ts. `prisma migrate` acquires a
# session-scoped advisory lock that is unreliable through a PgBouncer
# transaction-pooled endpoint and can fail with error P1002. For Neon, this is
# the same host as DATABASE_URL but WITHOUT the "-pooler" suffix. Falls back to
# DATABASE_URL if unset.
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# PORT: Port the Express API server listens on (the Vite dev server proxies /api to it).
PORT=3001
